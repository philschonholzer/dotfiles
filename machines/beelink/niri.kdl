// x86-specific configuration overrides
// This file contains only the differences from niri-base.kdl

include "niri-base.kdl"

input {
    mouse {
        left-handed
        natural-scroll
    }
}

layout {
    default-column-width { proportion 0.5; }
}

// LG Monitor configuration
output "DP-3" {
    mode "5120x2160"
    scale 1.6
    position x=0 y=0
}
